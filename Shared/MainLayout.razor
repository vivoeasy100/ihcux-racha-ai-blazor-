@inherits LayoutComponentBase

<div class="page">
    <div class="sidebar">
        <NavMenu />
    </div>

    <main>
        <div class="top-row px-4">
            <a href="https://learn.microsoft.com/aspnet/core/" target="_blank">Sobre o RachaAí</a>
        </div>

        <article class="content px-4">
            @Body
        </article>
    </main>
</div>

<style>
    .page {
        position: relative;
        display: flex;
        flex-direction: row;
        min-height: 100vh;
    }

    main {
        flex: 1;
        background-color: #f8f9fa;
    }

    .sidebar {
        background-image: linear-gradient(180deg, #1b6ec2 0%, #3a0647 100%);
        width: 250px;
        color: white;
    }

    .top-row {
        background-color: #f7f7f7;
        border-bottom: 1px solid #d6d5d5;
        justify-content: flex-end;
        height: 3.5rem;
        display: flex;
        align-items: center;
    }

    .top-row a {
        text-decoration: none;
        color: #1b6ec2;
    }

    .top-row a:hover {
        text-decoration: underline;
    }

    @@media (max-width: 767.98px) {
        .page {
            flex-direction: column;
        }

        .sidebar {
            width: 100%;
            height: auto;
        }
    }
</style>
